        "prettier": "^3.8.3",
        "react": "19.2.0",
        "react-native": "0.83.6",
        "react-native-health-connect": "^3.5.3"
    },
    "devDependencies": {
        "@types/react": "~19.2.2",
        "@types/xcode": "^3.0.0",
        "eslint": "^9.0.0",
        "eslint-config-expo": "~55.0.1",
        "expo-build-properties": "^55.0.14",
        "typescript": "~5.9.2"
    },
    "private": true
}
