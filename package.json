{
    "name": "krepa",
    "version": "1.0.0",
    "main": "index.ts",
    "scripts": {
        "plugins": "tsc --project tsconfig.plugins.json",
        "android": "npm run plugins && expo prebuild --clean && expo run:android",
        "android:dev": "expo run:android",
        "ios": "npm run plugins && expo prebuild --clean && expo run:ios",
        "ios:dev": "expo run:ios",
