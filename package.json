        "web": "expo start --web",
        "lint": "expo lint",
        "pretty": "prettier --write ."
    },
    "dependencies": {
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "expo": "~55.0.25",
